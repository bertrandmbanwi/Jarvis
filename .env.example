# ============================================================
# JARVIS Environment Configuration
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# Claude API Key (REQUIRED for cloud intelligence)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Model tier assignments (defaults shown; override if needed)
# CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
# CLAUDE_BRAIN_MODEL=claude-sonnet-4-6
# CLAUDE_DEEP_MODEL=claude-opus-4-6

# Default tier for general chat: fast, brain, or deep
# CLAUDE_DEFAULT_TIER=brain

# Prefer Claude over Ollama when both are available
# PREFER_CLAUDE=true

# Cost alert thresholds (USD)
# COST_DAILY_ALERT=2.00
# COST_MONTHLY_ALERT=60.00

# Ollama fallback (used when Claude API is unreachable)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# Voice settings
# WHISPER_MODEL=base.en
# TTS_ENGINE=kokoro
# TTS_VOICE=af_heart

# Authentication
# Set a custom PIN for remote access (4-8 digits).
# If not set, JARVIS auto-generates a random 6-digit PIN on first run.
# JARVIS_PIN=1234
# Set to true to regenerate a random PIN (ignores JARVIS_PIN)
# JARVIS_REGEN_PIN=false

# Server ports
# API_PORT=8741
# UI_PORT=3741

# Logging
# LOG_LEVEL=INFO
